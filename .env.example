# ============================================================
# Nyanbook Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.
# ============================================================

# ------------------------------------------------------------
# DATABASE (PostgreSQL / Supabase)
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------------------------
# SESSION
# Change this to a long random string before production.
# ------------------------------------------------------------
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ------------------------------------------------------------
# DISCORD — 4 specialized bots + 1 ledger webhook
# Create bots at: https://discord.com/developers/applications
# ------------------------------------------------------------
HERMES_TOKEN=your-hermes-bot-token
THOTH_TOKEN=your-thoth-bot-token
IDRIS_TOKEN=your-idris-bot-token
HORUS_TOKEN=your-horus-bot-token

# Webhook URL for the ledger Discord channel
NYANBOOK_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ------------------------------------------------------------
# WHATSAPP — Twilio WhatsApp Business API
# Webhook: POST /api/twilio/webhook
# https://twilio.com
# ------------------------------------------------------------
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_ACCOUNT_SID=your-twilio-account-sid

# Optional: restrict which WhatsApp groups/numbers are processed
# ALLOWED_GROUPS=Family Group,Work Team
# ALLOWED_NUMBERS=1234567890,9876543210

# ------------------------------------------------------------
# LINE OA — LINE Messaging API (listen-only inpipe)
# Webhook: POST /api/line/webhook
# https://developers.line.biz
# ------------------------------------------------------------
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# ------------------------------------------------------------
# AI — Groq (Llama 3.3 70B)
# https://console.groq.com
# ------------------------------------------------------------
PLAYGROUND_GROQ_TOKEN=your-groq-api-key
# Optional: separate vision model key (falls back to PLAYGROUND_GROQ_TOKEN)
# PLAYGROUND_GROQ_VISION_TOKEN=your-groq-vision-api-key

# ------------------------------------------------------------
# SEARCH — Brave Search API (web search in playground)
# https://brave.com/search/api/
# ------------------------------------------------------------
PLAYGROUND_BRAVE_API=your-brave-search-api-key

# ------------------------------------------------------------
# EMAIL — Resend (password reset, book sharing invites)
# https://resend.com
# ------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key

# ------------------------------------------------------------
# IPFS — Pinata (ZK-ready capsule pinning, optional)
# Without this, IPFS pinning is skipped gracefully (null CID).
# https://pinata.cloud — free 1GB tier
# ------------------------------------------------------------
PINATA_JWT=your-pinata-jwt-token

# ------------------------------------------------------------
# NYAN API v1 — Internal agent-to-agent API tokens
# Generate your own random strings (min 32 chars).
# ------------------------------------------------------------
NYAN_API_TOKEN_3=your-production-api-token
NYAN_API_TOKEN_DEV=your-dev-api-token

# ------------------------------------------------------------
# OPTIONAL
# ------------------------------------------------------------

# CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=https://yourdomain.com

# Rate limit exempt IPs (comma-separated, in addition to localhost)
# RATE_LIMIT_EXEMPT_IPS=10.0.0.1

# Port (default: 5000)
# PORT=5000
