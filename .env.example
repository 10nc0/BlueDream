# Required: Your Discord webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: Filter by specific group names (comma-separated, case-insensitive partial match)
# Example: ALLOWED_GROUPS=Family Group,Work Team,Project Alpha
# ALLOWED_GROUPS=

# Optional: Filter by specific phone numbers (comma-separated, without + or spaces)
# Example: ALLOWED_NUMBERS=1234567890,9876543210
# ALLOWED_NUMBERS=

# If both ALLOWED_GROUPS and ALLOWED_NUMBERS are empty:
# Only messages sent TO the bot (direct messages) will be forwarded.

# Optional: Path to Chromium executable (auto-detected on NixOS)
# PUPPETEER_EXECUTABLE_PATH=/path/to/chromium
