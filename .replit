modules = ["postgresql-16", "nodejs-22"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WhatsApp Bridge"

[[workflows.workflow]]
name = "WhatsApp Bridge"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node vegapunk.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "vegapunk.js"]

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_DOMAIN = "nyanbook.io"
