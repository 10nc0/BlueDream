modules = ["python-3.11", "nodejs-20", "postgresql-16", "java-graalvm22.3"]
[agent]
expertMode = true
integrations = ["discord:1.0.0", "javascript_openai_ai_integrations:1.0.0", "twilio:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["chromium", "nano", "q-text-as-data", "try", "mailutils"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WhatsApp Bridge"

[[workflows.workflow]]
name = "WhatsApp Bridge"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 36221
externalPort = 80

[[ports]]
localPort = 38893
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "index.js"]
