modules = ["python-3.11", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true
integrations = ["discord:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["chromium"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WhatsApp Bridge"

[[workflows.workflow]]
name = "WhatsApp Bridge"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33125
externalPort = 3002

[[ports]]
localPort = 34271
externalPort = 3001

[[ports]]
localPort = 37635
externalPort = 3000

[[ports]]
localPort = 41077
externalPort = 3003

[deployment]
deploymentTarget = "cloudrun"
