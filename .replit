modules = ["python-3.11", "nodejs-20", "java-graalvm22.3", "postgresql-16"]
[agent]
expertMode = true
integrations = ["discord:1.0.0", "javascript_openai_ai_integrations:1.0.0", "twilio:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["chromium", "glibcLocales", "libuuid", "mailutils", "nano", "poppler", "poppler-utils", "q-text-as-data", "try", "gcc-unwrapped"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nyanbook"

[[workflows.workflow]]
name = "Nyanbook"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node vegapunk.js"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "vegapunk.js"]

[userenv]

[userenv.shared]
RATE_LIMIT_EXEMPT_IPS = "10.83.9.13"
LIMBO_THREAD_ID = "1433850939751534672"
TWILIO_WEBHOOK_URL = "https://Nyanbook.replit.app/api/twilio/webhook"
