{
  "name": "workspace",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "audit-ui": "node tests/ui-audit/scripts/generate-test-pages.js && npx playwright test",
    "audit-ui:update": "node tests/ui-audit/scripts/generate-test-pages.js && npx playwright test --update-snapshots",
    "audit-ui:report": "npx playwright show-report tests/ui-audit/screenshots/html-report",
    "audit:watch": "chokidar \"public/**/*.{html,css,js}\" \"tests/ui-audit/**/*\" -c \"npm run audit-ui\" --initial --debounce 2000",
    "dev": "concurrently -n \"server,audit\" -c \"blue,green\" \"node index.js\" \"npm run audit:watch\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@playwright/test": "^1.56.1",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "connect-pg-simple": "^10.0.0",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "form-data": "^4.0.4",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.7.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "playwright": "^1.56.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "twilio": "^5.10.3",
    "whatsapp-web.js": "^1.34.1"
  }
}
